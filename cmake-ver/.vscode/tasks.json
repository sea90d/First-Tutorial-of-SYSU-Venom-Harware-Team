{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure Debug",
      "type": "process",
      "command": "cmake",
      "args": [
        "--preset",
        "Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: Build Debug",
      "type": "process",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "Debug",
        "-j"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "CMake: Configure Debug"
      ],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "STM32: Build and Flash",
      "type": "process",
      "command": "D:\\CLT\\STM32CubeCLT_1.21.0\\STM32CubeProgrammer\\bin\\STM32_Programmer_CLI.exe",
      "args": [
        "-c",
        "port=SWD",
        "-w",
        "${workspaceFolder}\\build\\Debug\\Desktop.elf",
        "-v",
        "-rst"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "CMake: Build Debug"
      ],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "STM32: Build and Flash (Under Reset)",
      "type": "process",
      "command": "D:\\CLT\\STM32CubeCLT_1.21.0\\STM32CubeProgrammer\\bin\\STM32_Programmer_CLI.exe",
      "args": [
        "-c",
        "port=SWD",
        "mode=UR",
        "-w",
        "${workspaceFolder}\\build\\Debug\\Desktop.elf",
        "-v",
        "-rst"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "CMake: Build Debug"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
